-- ESP
-- ===============================
local espObjects = {}
local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local character = player.Character
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            local humanoid = character:FindFirstChild("Humanoid")
            
            if Settings.ESP and rootPart and humanoid and humanoid.Health > 0 then
                if not espObjects[player] then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Size = Vector3.new(3, 4.5, 2)
                    box.Adornee = rootPart
                    box.AlwaysOnTop = true
                    box.Parent = rootPart
                    
                    local billboard = Instance.new("BillboardGui")
                    billboard.Size = UDim2.new(0, 200, 0, 40)
                    billboard.Adornee = rootPart
                    billboard.AlwaysOnTop = true
                    
                    local text = Instance.new("TextLabel")
                    text.Size = UDim2.new(1, 0, 1, 0)
                    text.BackgroundTransparency = 1
                    text.Font = Enum.Font.GothamBold
                    text.TextSize = 12
                    text.Parent = billboard
                    
                    billboard.Parent = rootPart
                    espObjects[player] = {box = box, billboard = billboard, text = text}
                end
                
                local data = espObjects[player]
                if data.box then
                    data.box.Color3 = ESPColors[currentESPColor]
                    data.box.Visible = Settings.ESPBox
                end
                
                if data.text then
                    local info = Settings.ESPName and player.Name or ""
                    if Settings.ESPDistance then
                        local dist = (rootPart.Position - Camera.CFrame.Position).Magnitude
                        info = info .. (info ~= "" and " [" .. math.floor(dist) .. "m]" or "")
                    end
                    data.text.Text = info
                    data.text.TextColor3 = ESPColors[currentESPColor]
                    data.billboard.Visible = (Settings.ESPName or Settings.ESPDistance)
                end
            elseif espObjects[player] then
                if espObjects[player].box then espObjects[player].box:Destroy() end
                if espObjects[player].billboard then espObjects[player].billboard:Destroy() end
                espObjects[player] = nil
            end
        end
    end
end

RunService.RenderStepped:Connect(UpdateESP)

